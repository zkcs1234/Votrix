# =============================================================================
# VOTRIX API — Production deployment (Render + Supabase)
# Copy to .env locally or set in Render Dashboard → Environment
# =============================================================================

NODE_ENV=production
PORT=5000

# Frontend URL (required in production — must match Vercel URL exactly, https)
FRONTEND_URL=https://your-app.vercel.app
# Legacy alias (optional if FRONTEND_URL is set)
# CLIENT_URL=https://your-app.vercel.app
# Extra origins for Vercel preview deploys (comma-separated, optional)
# CLIENT_URLS=https://your-app-git-main.vercel.app

# Cross-origin cookies (Vercel + Render). Default in production: none
# COOKIE_SAME_SITE=none

# JWT — use long random strings (openssl rand -hex 32)
JWT_SECRET=
JWT_REFRESH_SECRET=
# Or explicit names:
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CSRF (required in production — min 32 characters)
CSRF_SECRET=

# Supabase (run all migrations in SQL Editor)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary (uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (email workflows)
RESEND_API_KEY=
EMAIL_FROM=VOTRIX <noreply@yourdomain.com>
# Legacy alias: RESEND_FROM_EMAIL=

PASSWORD_RESET_EXPIRY_MINUTES=60
