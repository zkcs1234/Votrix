{
  "name": "votrix-backend",
  "version": "1.0.0",
  "description": "VOTRIX API — Online Voting, Polling, and Competition Scoring",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "kill-port": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 5000",
    "dev:clean": "npm run kill-port && npm run dev",
    "db:hash-password": "node src/database/scripts/hash-password.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "votrix",
    "voting",
    "polling"
  ],
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "resend": "^6.12.4",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "vitest": "^4.1.7"
  }
}
